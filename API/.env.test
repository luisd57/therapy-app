# .env.test - Test environment overrides
APP_ENV=test
APP_SECRET=test_secret_for_testing_only
TRUSTED_PROXIES=127.0.0.1

# Database - same host, doctrine.yaml appends _test suffix automatically
DATABASE_URL="postgresql://therapy_user:therapy_pass@postgres:5432/therapy_db?serverVersion=16&charset=utf8"

# JWT - reuse dev keys
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=therapy_jwt_passphrase
JWT_TOKEN_TTL=3600

# Mailer - null transport (no actual emails sent)
MAILER_DSN=null://null

# App settings
APP_FRONTEND_URL=http://localhost:3000
INVITATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600
