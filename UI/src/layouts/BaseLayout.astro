---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Psicóloga Clínica — Terapia Online e Presencial',
  description = 'Agenda tu cita de terapia psicológica. Atención online y presencial.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-900 font-sans antialiased">
    <slot />
  </body>
</html>
